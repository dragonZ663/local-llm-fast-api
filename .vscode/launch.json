{
    "version": "0.2.0",
    "configurations": [
      {
        "name": "FastAPI (uvicorn, debug)",
        "type": "debugpy",
        "request": "launch",
        "module": "uvicorn",
        "args": [
          "app.main:app",
          "--host",
          "0.0.0.0",
          "--port",
          "8000"
        ],
        "cwd": "${workspaceFolder}",
        "envFile": "${workspaceFolder}/.env",
        "justMyCode": true,
        "console": "integratedTerminal"
      },
      {
        "name": "FastAPI (uvicorn, reload, debug)",
        "type": "debugpy",
        "request": "launch",
        "module": "uvicorn",
        "args": [
          "app.main:app",
          "--host",
          "0.0.0.0",
          "--port",
          "8000",
          "--reload"
        ],
        "cwd": "${workspaceFolder}",
        "envFile": "${workspaceFolder}/.env",
        "justMyCode": true,
        "console": "integratedTerminal"
      },
      {
        "name": "Attach debugpy :5678",
        "type": "debugpy",
        "request": "attach",
        "connect": {
          "host": "127.0.0.1",
          "port": 5678
        },
        "justMyCode": true
      }
    ]
  }